rule plot_pfam_frequency:
    input:
        neighborhood = f"{SYNTENY_DIR}/neighborhood_csv/{{protein}}.neighborhood.csv",
        genome_file  = config["genome_file"],
        pfam_out = f"{SYNTENY_DIR}/neighborhood_csv/{{protein}}.pfam_neigh.tsv"
    output:
        outdir = directory(f"{SYNTENY_DIR}/pfam_plots/{{protein}}/{{taxa_level}}/cluster_freq"),
        done = f"{SYNTENY_DIR}/pfam_plots/{{protein}}/{{taxa_level}}/done.txt",
    params:
        top_n       = config.get("top_n",       25),
        min_genomes = config.get("min_genomes", 1),
    conda:
        f"{config['env_dir']}/Reg.yaml" 
    shell:
        """
        python {CURRENT_DIR}/bin/units/plot_pfam_frequency.py \
            --input       {input.neighborhood}         \
            --pfam_map    {input.pfam_out}             \
            --outdir      {output.outdir}              \
            --protein     {wildcards.protein}          \
            --genome_file {input.genome_file}          \
            --tax_level   {wildcards.taxa_level}       \
            --top_n       {params.top_n}               \
            --min_genomes {params.min_genomes}         

        touch {output.done}
        """


