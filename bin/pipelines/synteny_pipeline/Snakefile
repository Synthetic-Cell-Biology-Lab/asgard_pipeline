########################################
# Main Snakefile
########################################

from datetime import datetime
import os
import shutil
import sys
import glob

# Expect config from CLI
if not config:
    raise ValueError("No config provided. Use --configfile.")


import pandas as pd

genome_df = pd.read_csv(config["genome_file"])

TAXA_LEVELS = config['taxa_levels']


TAXA_DICT = {level: genome_df[level].dropna().unique().tolist()
            for level in TAXA_LEVELS}
PROTEIN = config["protein_name"]

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
RUN_ID = config.get("run_id", TIMESTAMP)


LOG = config['pipeline_log']
BASE_DIR = os.getcwd()
CURRENT_DIR = config.get('base_dir', workflow.basedir)
RESULT_DIR = config.get("parent_dir", f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}")
SYNTENY_DIR = f"{RESULT_DIR}/synteny"


# Create directories
os.makedirs(RESULT_DIR, exist_ok=True)
os.makedirs(SYNTENY_DIR, exist_ok=True)


# Include rule definitions



FINAL_TARGETS = [
    f"{RESULT_DIR}/synteny_pipeline.log",
    f"{SYNTENY_DIR}/{RUN_ID}.synteny.html",
    f"{SYNTENY_DIR}/{RUN_ID}.top_genomes_per_class.csv",
    f"{SYNTENY_DIR}/{RUN_ID}.top_quality_genomes_per_class.csv"
    
]


FINAL_TARGETS.extend(
    expand(f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/done.txt",
    protein = config['gene_neighborhood_protein_sets'],
    taxa_level = config['taxa_levels'])
)



rule all:
    input:
        FINAL_TARGETS


rule link_log_file:
    output:
        f"{RESULT_DIR}/synteny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"


if config.get("from_existing_folder", False):
    include: "rules/from_existing_folder.smk"
elif config.get("from_database", False):
    include: "rules/from_database.smk"
else:
    print("Must include atleast one mode of id extraction")
    sys.exit()

rule top_genome_by_quality_per_class:
    input:
        genome_file = config["genome_file"]
    output:
        f"{SYNTENY_DIR}/{RUN_ID}.top_quality_genomes_per_class.csv"
    params:
        taxa_levels = ",".join(config["taxa_levels"]),
        completeness_col = config.get("completeness_col", "completeness"),
        contamination_col = config.get("contamination_col", "contamination")
    conda:
        f"{config['env_dir']}/duckdb_handler.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/top_quality_genome_per_class.py \
            --genome_file {input.genome_file} \
            --taxa_levels {params.taxa_levels} \
            --completeness_col {params.completeness_col} \
            --contamination_col {params.contamination_col} \
            --output {output}
        """

rule top_genome_per_class:
    input:
        csv = f"{SYNTENY_DIR}/{RUN_ID}.synteny.csv",
        genome_file = config["genome_file"]
    output:
        f"{SYNTENY_DIR}/{RUN_ID}.top_genomes_per_class.csv"
    params:
        taxa_levels = ",".join(config["taxa_levels"])
    conda:
        f"{config['env_dir']}/duckdb_handler.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/top_genome_per_class.py \
            --synteny_csv {input.csv} \
            --genome_file {input.genome_file} \
            --taxa_levels {params.taxa_levels} \
            --output {output}
        """


rule get_and_modify_gbk:
    input:
        csv = f"{SYNTENY_DIR}/{RUN_ID}.synteny.csv"
    output:
        gbk = temp(f"{SYNTENY_DIR}/gbkfiles/{{genome}}.synteny.gbk")
    params:
        window = config.get("nucleotide_window", 5000),
        gbk_database_path = config.get("gbk_database")
    conda:
        f"{config['env_dir']}/Reg.yaml"
    message:
        """
        ==========================================
        Extracting synteny for {wildcards.genome}
        ==========================================
        """
    shell:
        """
        python {CURRENT_DIR}/bin/units/extract_synteny_2.py \
            --input_csv {input.csv} \
            --genome {wildcards.genome} \
            --database_path {params.gbk_database_path} \
            --window {params.window} \
            --output {output.gbk}
        """


rule annotate_domains:
    input:
        gbk = f"{SYNTENY_DIR}/gbkfiles/{{genome}}.synteny.gbk"
    output:
        gbk = f"{SYNTENY_DIR}/gbkfiles/{{genome}}.domains.gbk"
    params:
        parquet = config["interproscan_file"]
    conda:
        f"{config['env_dir']}/duckdb_handler.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/annotate_gbk_w_ips.py \
            --input_gbk {input.gbk} \
            --output_gbk {output.gbk} \
            --parquet {params.parquet}
        """


rule synteny_plot:
    input:
        expand(
            f"{SYNTENY_DIR}/gbkfiles/{{genome}}.domains.gbk",
            genome=config["synteny_plot_genomes"]
        )
    output:
        html_file = f"{SYNTENY_DIR}/{RUN_ID}.synteny.html"
    conda:
        f"{config['env_dir']}/clinker.yaml"
    shell:
        """
        clinker {SYNTENY_DIR}/gbkfiles/*.domains.gbk -p {output.html_file}
        """


rule quantify_neighborhood:
    input:
        csv = f"{SYNTENY_DIR}/{RUN_ID}.synteny.csv",
        parquet = config["interproscan_full"]
    output:
        protein_csv = f"{SYNTENY_DIR}/neighborhood_csv/{{protein}}.neighborhood.csv"
    params:
        window = config.get("nucleotide_window", 5000),
        protein_column = config.get("protein_column", "Manual_annotation"),
        gbk_path = config["gbk_database"],
        tax_levels = ",".join(config.get("taxa_levels", []))

    conda:
        f"{config['env_dir']}/duckdb_handler.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/get_protein_neighborhoods.py \
                --filtered_proteins {input.csv} \
                --protein_col {params.protein_column} \
                --ips {input.parquet} \
                --protein {wildcards.protein} \
                --window {params.window} \
                --gbk_path {params.gbk_path} \
                --tax_levels {params.tax_levels} \
                --out {output.protein_csv}

        """


rule cluster_neighborhood:
    input:
        f"{SYNTENY_DIR}/neighborhood_csv/{{protein}}.neighborhood.csv"
    output:
        f"{SYNTENY_DIR}/clustered_csv/{{protein}}.clustered.csv"
    conda:
        f"{config['env_dir']}/Reg.yaml"
        
    shell:
        """
        python {CURRENT_DIR}/bin/units/cluster_neighborhood.py \
            --input {input} \
            --column IPS_acc \
            --output {output}
        """



rule plot_cluster_frequency:
    input:
        clustered = f"{SYNTENY_DIR}/clustered_csv/{{protein}}.clustered.csv",
        genome_file = config['genome_file']

    output:
        freq = directory(f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/cluster_freq"),
        syn_score = directory(f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/synteny_score"),
        done = f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/done.txt"
    conda:
        f"{config['env_dir']}/bio-r.yaml"
    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/plot_clusters2.r \
            --input "{input.clustered}" \
            --output "{output.freq}" \
            --output2 "{output.syn_score}" \
            --tax_level "{wildcards.taxa_level}" \
            --genome_file "{input.genome_file}" \
            --protein "{wildcards.protein}"
        touch {output.done}
        """
