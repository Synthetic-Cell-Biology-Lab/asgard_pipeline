                --out {output.protein_csv} \
                --subset_gbk {params.subset}
        """

rule collate_neighborhoods:
    input:
        expand(f"{SYNTENY_DIR}/neighborhood_csv/{{protein}}.synteny_neighborhood.csv",
        protein = config['gene_neighborhood_protein_sets'])

    output:
        f"{SYNTENY_DIR}/neighborhood_csv/combined.synteny_neighborhood.csv"
    conda:
        f"{config['env_dir']}/Reg.yaml"

    run:
        import pandas as pd

        dfs = []

        for f in input:
            df = pd.read_csv(f)
            dfs.append(df)

        combined = pd.concat(dfs, ignore_index=True)

        combined = combined.drop_duplicates(
            subset=["neighbor_locus"]
        )

        combined.to_csv(output[0], index=False)

