        """




rule synteny_plot:
    input:
        gbks = expand(
            f"{SYNTENY_DIR}/gbkfiles/{{genome}}.domains.gbk",
            genome=config["synteny_plot_genomes"]
        )

    output:
        html_file = f"{SYNTENY_DIR}/{RUN_ID}.synteny.html",
        json = f"{SYNTENY_DIR}/{RUN_ID}.synteny.json"

    conda:
        f"{config['env_dir']}/clinker.yaml"

    shell:
        """
        clinker {input.gbks} \
            -p {output.html_file} \
            -s {output.json} \
        """

