rule plot_cluster_frequency:
    input:
        clustered = f"{SYNTENY_DIR}/clustered_csv/{{protein}}.clustered.csv",
        genome_file = config['genome_file']

    output:
        freq = directory(f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/cluster_freq"),
        syn_score = directory(f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/synteny_score"),
        done = f"{SYNTENY_DIR}/cluster_plots/{{protein}}/{{taxa_level}}/done.txt"
    conda:
        f"{config['env_dir']}/bio-r.yaml"
    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/plot_clusters2.r \
            --input "{input.clustered}" \
            --output "{output.freq}" \
            --output2 "{output.syn_score}" \
            --tax_level "{wildcards.taxa_level}" \
            --genome_file "{input.genome_file}" \
            --protein "{wildcards.protein}"
        touch {output.done}
        """
