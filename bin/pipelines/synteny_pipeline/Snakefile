    params:
        taxa_levels = ",".join(config["taxa_levels"]),
        completeness_col = config.get("completeness_col", "Completeness"),
        contamination_col = config.get("contamination_col", "Contamination")
    conda:
        f"{config['env_dir']}/duckdb_handler.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/top_quality_genome_per_class.py \
            --genome_file {input.genome_file} \
            --taxa_levels {params.taxa_levels} \
            --completeness_col {params.completeness_col} \
            --contamination_col {params.contamination_col} \
            --output {output}
        """

