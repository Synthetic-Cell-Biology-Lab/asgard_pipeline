# =========================
# Top-level constants
# =========================

OUTDIR = config["output_dir"]
ORGS   = [org["name"].replace(" ", "_").lower() for org in config["organisms"]]
STAGES = config["pipeline_stages"]
FINAL_STAGE = STAGES[-1]


# =========================
# Helper functions
# (must be defined before any code that calls them)
# =========================

def stage_dir(org, stage):
    stage_map = {
        "raw":      f"{OUTDIR}/{org}/genomes",
        "filtered": f"{OUTDIR}/{org}/filtered",
        "derep":    f"{OUTDIR}/skder/{org}",
    }
    return stage_map[stage]


def prev_stage_dir(org, stage):
    idx = STAGES.index(stage)
    if idx == 0:
        raise ValueError(f"Stage '{stage}' has no previous stage")
    return stage_dir(org, STAGES[idx - 1])


def get_org_param(wc, field, default=None):
    org = next(
        o for o in config["organisms"]
        if o["name"].replace(" ", "_").lower() == wc.org
    )
    return org.get(field, default)


# =========================
# Bakta configuration
# =========================

BAKTA_EXISTING = config.get("cds", {}).get("existing")

if BAKTA_EXISTING:
    BAKTA_OUTDIR     = Path(BAKTA_EXISTING)
    EXISTING_GENOMES = {p.name for p in BAKTA_OUTDIR.iterdir() if p.is_dir()}
else:
    BAKTA_OUTDIR     = Path(f"{OUTDIR}/bakta")
    EXISTING_GENOMES = set()


# =========================
# Collect dereplicated genome files
# (depends on stage_dir, so must come after it)
# =========================

GENOME_FILES = []
for org in ORGS:
    genome_dir = Path(
        f"{stage_dir(org, FINAL_STAGE)}/Dereplicated_Representative_Genomes"
    )
    if genome_dir.exists():
        GENOME_FILES.extend(genome_dir.glob("*.fna"))

# Genome names without extension
ALL_GENOMES = {genome.stem: genome for genome in GENOME_FILES}

# Genomes that still need Bakta annotation
GENOMES_TO_RUN = sorted([
    genome for genome in ALL_GENOMES
    if genome not in EXISTING_GENOMES
])


# =========================
# Rules
# =========================

rule all:
    input:
        expand(f"{OUTDIR}/{{org}}/done.flag",                      org=ORGS),
        expand(f"{OUTDIR}/skder/{{org}}/dedup_done.flag",          org=ORGS),
        expand(f"{OUTDIR}/checkm2/{{org}}/checkm2_done.flag",      org=ORGS),
        expand(f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk_done.flag",        org=ORGS),
        expand(f"{OUTDIR}/gtdbtk/{{org}}_taxa_count.svg",          org=ORGS),
        expand(f"{BAKTA_OUTDIR}/{{genome}}",                        genome=GENOMES_TO_RUN),
        f"{OUTDIR}/interproscan/ips_done.flag"


rule download_genomes:
    output:
        zipfile = f"{OUTDIR}/{{org}}/dataset.zip"
    params:
        name   = lambda wc: get_org_param(wc, "name"),
        level  = lambda wc: " ".join(
            f"--assembly-level {l}"
            for l in (get_org_param(wc, "assembly_level") or [])
        ),
        refseq = lambda wc: "--reference" if get_org_param(wc, "refseq_only") else ""
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    shell:
        """
        datasets download genome taxon "{params.name}" \
            {params.level} \
            {params.refseq} \
            --include genome \
            --filename {output.zipfile}
        """


rule extract_genomes:
    input:
        zipfile = f"{OUTDIR}/{{org}}/dataset.zip"
    output:
        flag    = f"{OUTDIR}/{{org}}/done.flag",
        genomes = directory(f"{OUTDIR}/{{org}}/genomes")
    shell:
        """
        mkdir -p {output.genomes}

        unzip -o {input.zipfile} \
            -d {OUTDIR}/{wildcards.org}/

        find {OUTDIR}/{wildcards.org}/ncbi_dataset/data/ \
            -name "*.fna" \
            -exec ln -sf {{}} {output.genomes}/ \;

        touch {output.flag}
        """


rule checkm2:
    input:
        flag        = f"{OUTDIR}/{{org}}/done.flag",
        genomes_dir = f"{OUTDIR}/{{org}}/genomes"
    output:
        outdir         = directory(f"{OUTDIR}/checkm2/{{org}}"),
        checkm2_flag   = f"{OUTDIR}/checkm2/{{org}}/checkm2_done.flag",
        quality_report = f"{OUTDIR}/checkm2/{{org}}/quality_report.tsv"
    threads: 16
    params:
        db = config["checkm2"]["db_path"]
    conda:
        f"{config.get('env_dir')}/checkm2.yaml"
    shell:
        """
        checkm2 predict \
            --input {input.genomes_dir} \
            --output-directory {output.outdir} \
            --database_path {params.db} \
            --extension fna \
            --threads {threads} \
            --force

        touch {output.checkm2_flag}
        """


rule move_filtered:
    input:
        quality_report = f"{OUTDIR}/checkm2/{{org}}/quality_report.tsv",
        genomes_dir    = lambda wc: stage_dir(wc.org, "raw")   # FIX: was prev_stage_dir(wc.org, "filtered")
    output:
        filtered_dir  = directory(f"{OUTDIR}/{{org}}/filtered"),
        filtered_list = f"{OUTDIR}/{{org}}/filtered/passed_genomes.txt"
    threads: 1
    params:
        cont         = config["checkm2"]["Contamination"],
        completeness = config["checkm2"]["Completeness"]
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    shell:
        """
        mkdir -p {output.filtered_dir}

        awk -F' ' \
            -v completeness={params.completeness} \
            -v cont={params.cont} \
            'NR > 1 && $2 >= completeness && $3 <= cont {{ print $1 }}' \
            {input.quality_report} \
        > {output.filtered_list}

        while read genome; do
            cp {input.genomes_dir}/${{genome}}.fna {output.filtered_dir}/
        done < {output.filtered_list}
        """


rule skder:
    input:
        genomes_dir = lambda wc: prev_stage_dir(wc.org, "derep"),
        stage_list  = lambda wc: f"{prev_stage_dir(wc.org, 'derep')}/passed_genomes.txt"
    output:
        derep_dir  = directory(f"{OUTDIR}/skder/{{org}}"),
        derep_list = f"{OUTDIR}/skder/{{org}}/derep_genomes.txt",
        flag       = f"{OUTDIR}/skder/{{org}}/dedup_done.flag"
    threads: 16
    params:
        ani    = config['deduplication']['ani'],
        min_af = config['deduplication']['min_af']
    conda:
        f"{config.get('env_dir')}/skder.yaml"
    shell:
        """
        skder -g {input.genomes_dir} \
              -o {output.derep_dir}  \
              -i {params.ani}        \
              -f {params.min_af}     \
              -c {threads}

        ls {output.derep_dir}/Dereplicated_Representative_Genomes/ \
            | sed 's/\\.fna$//' \
            > {output.derep_list}

        touch {output.flag}
        """


rule gtdbtk:
    input:
        genomes_dir = lambda wc: f"{stage_dir(wc.org, STAGES[-1])}/Dereplicated_Representative_Genomes",
        derep_list  = lambda wc: f"{stage_dir(wc.org, STAGES[-1])}/derep_genomes.txt",
        db_dir      = ancient(config["gtdb"]["db_path"])
    output:
        outdir = directory(f"{OUTDIR}/gtdbtk/{{org}}"),
        flag   = f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk_done.flag"
    threads:
        config["gtdb"].get("threads", 16)
    params:
        db           = config["gtdb"]["db_path"],
        extension    = config["gtdb"].get("extension",    "fna"),
        prefix       = config["gtdb"].get("prefix",       "gtdbtk"),
        min_perc_aa  = config["gtdb"].get("min_perc_aa",  10),
        min_af       = config["gtdb"].get("min_af",       0.65),
        pplacer_cpus = config["gtdb"].get("pplacer_cpus", 4),
        scratch_dir  = config["gtdb"].get("scratch_dir",  "/tmp"),
        extra_args   = config["gtdb"].get("extra_args",   "")
    conda:
        f"{config.get('env_dir')}/gtdbtk.yaml"
    shell:
        """
        export GTDBTK_DATA_PATH={params.db}

        gtdbtk classify_wf \
            --genome_dir   {input.genomes_dir}      \
            --out_dir      {output.outdir}           \
            --extension    {params.extension}        \
            --prefix       {params.prefix}           \
            --min_perc_aa  {params.min_perc_aa}      \
            --min_af       {params.min_af}           \
            --cpus         {threads}                 \
            --pplacer_cpus {params.pplacer_cpus}     \
            --scratch_dir  {params.scratch_dir}      \
            {params.extra_args}

        touch {output.flag}
        """


rule split_taxonomy:
    input:
        f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk.ar53.summary.tsv"
    output:
        f"{OUTDIR}/gtdbtk/{{org}}_gtdbtk_classification_split.ar53.csv"
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    run:
        import pandas as pd

        df = pd.read_csv(input[0], sep="\t")

        ranks = ["domain", "phylum", "class",
                 "order", "family", "genus", "species"]

        tax_split = (
            df["classification"]
            .str.split(";", expand=True)
            .iloc[:, :7]
        )
        tax_split.columns = ranks

        for col in ranks:
            tax_split[col] = tax_split[col].str.replace(
                r"^[dpcofgs]__", "", regex=True
            )

        df = pd.concat([df, tax_split], axis=1)
        df['genome_file'] = df['user_genome']
        df.to_csv(output[0], index=False)


rule taxa_counts:
    input:
        csv = f"{OUTDIR}/gtdbtk/{{org}}_gtdbtk_classification_split.ar53.csv"
    output:
        plot = f"{OUTDIR}/gtdbtk/{{org}}_taxa_count.svg"
    conda:
        f"{config['env_dir']}/bio-r.yaml"
    message:
        """
        ==========================================
        📊      Taxonomic Sampling Plot
        ==========================================
        """
    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/plot_taxa_counts.r \
            -i {input.csv} \
            -o {output.plot}
        """


rule bakta:
    input:
        genome = lambda wc: str(ALL_GENOMES[wc.genome])
    output:
        outdir = directory(f"{BAKTA_OUTDIR}/{{genome}}")
    params:
        prefix   = "{genome}",
        bakta_db = config.get("cds", {}).get("bakta_db", "")
    threads: 4
    conda:
        f"{config['env_dir']}/bakta.yaml"
    shell:
        """
        bakta \
            --db {params.bakta_db} \
            --output {output.outdir} \
            --prefix {params.prefix} \
            --threads {threads} \
            {input.genome}
        """


import pandas as pd

def get_filtered_genomes():
    genomes = []
    for org in ORGS:
        csv_path = f"{OUTDIR}/gtdbtk/{org}_gtdbtk_classification_split.ar53.csv"
        if not os.path.exists(csv_path):
            continue
        df = pd.read_csv(csv_path)
        phyla = config['interproscan']['phylum_filter']
        if isinstance(phyla, str):
            phyla = [phyla]
        genomes.extend(df[df['phylum'].isin(phyla)]['user_genome'].tolist())
    return genomes

FILTERED_GENOMES = get_filtered_genomes()


rule interproscan:
    input:
        faa = f"{BAKTA_OUTDIR}/{{genome}}/{{genome}}.faa"
    output:
        tsv = f"{BAKTA_OUTDIR}/{{genome}}/{{genome}}_domains.tsv"
    params:
        base  = f"{BAKTA_OUTDIR}/{{genome}}/{{genome}}_domains",
        clean = f"{BAKTA_OUTDIR}/{{genome}}/{{genome}}_clean.faa"
    threads: 4
    resources:
        mem_mb = 15000
    shell:
        """
        mkdir -p interpro_temp/{wildcards.genome} logs

        sed '/^>/! s/\*//g' {input.faa} > {params.clean}

        /home/anirudh/interproscan/interproscan.sh \
            -i {params.clean} \
            -f tsv,xml,gff3 \
            -appl Pfam,Gene3D,SUPERFAMILY \
            -dp -goterms -pa \
            -cpu {threads} \
            -T interpro_temp/{wildcards.genome} \
            -b {params.base} \
            > logs/{wildcards.genome}.log 2>&1

        rm -f {params.clean}
        """


rule all_interproscan:
    input:
        lambda wc: expand(
            f"{BAKTA_OUTDIR}/{{genome}}/{{genome}}_domains.tsv",
            genome = FILTERED_GENOMES
        )
    output:
        done_flag = f"{OUTDIR}/interproscan/ips_done.flag"
    shell:
        """
        touch {output.done_flag}
        
        """