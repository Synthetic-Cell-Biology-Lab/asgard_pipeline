# get the summary of genomse deposited in the ncbi-datasets with our specifications
rule get_summary:
    """
    The input taken (in params) is the organism name that is matching to ncbi-dataset
    in the config file

    Gives output of a summary file matching the constraints provided from ncbi-datasets  
    Search yields serveral reports per genome, needs to be deduplicated.
    """
    output:
        summary=f"{OUTDIR}/{{org}}/genomes_summary.tsv"
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    params:
        name=lambda wc: get_org_param(wc, "name"),
        level=lambda wc: " ".join(
            f"--assembly-level {l}"
            for l in (get_org_param(wc, "assembly_level") or [])
        ),
        refseq=lambda wc: "--reference" if get_org_param(wc, "refseq_only") else ""
    shell:
        r"""
        # The input given is the name of the organism, convert to taxa id
        TAXID=$(
            datasets summary taxonomy taxon "{params.name}" \
                --as-json-lines \
            | dataformat tsv taxonomy --template tax-summary \
            | awk 'NR==2 {{print $2}}'
        )
        
        datasets summary genome taxon "$TAXID" \
            {params.level} \
            {params.refseq} \
            --as-json-lines \
        | dataformat tsv genome \
        > {output.summary}
        """




rule prepare_download_list:
    """
    Takes input of the summary file and the genomes in the database 
    and creates a list that is not there in our database
    
    """
    input:
        summary=f"{OUTDIR}/{{org}}/genomes_summary.tsv",
        genomes_present = f"{OUTDIR}/{{org}}/present_list.txt"
    output:
        accession_list = f"{OUTDIR}/{{org}}/accession_list_to_download.txt"
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    run:
        import pandas as pd

        summary_df = pd.read_csv(input.summary, sep="\t")
        with open(input.genomes_present) as f:
            present_list = [
                "_".join(line.strip().split("_")[:2])
                for line in f
                if line.strip()
            ]

        to_be_downloaded = set(summary_df['Assembly Accession'].tolist()) - set(present_list)

        with open(output.accession_list, 'w') as out:
            out.write("\n".join(list(to_be_downloaded)))
        




