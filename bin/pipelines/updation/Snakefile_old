rule extract_genomes:
# extracts genomes and rehydrates them to recover full file
    input:
        zipfile = f"{OUTDIR}/{{org}}/dataset.zip"
    output:
        flag    = f"{OUTDIR}/{{org}}/done.flag",
        genomes = directory(f"{OUTDIR}/{{org}}/genomes")
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    shell:
        """
        mkdir -p {output.genomes}

        unzip -o {input.zipfile} \
            -d {OUTDIR}/{wildcards.org}/
        
        datasets rehydrate --directory  {OUTDIR}/{wildcards.org}/

        find {OUTDIR}/{wildcards.org}/ncbi_dataset/data/ \
            -name "*.fna" \
            -exec ln -sf {{}} {output.genomes}/ \;

        touch {output.flag}
        """


rule checkm2:
    """
    Given that we are working with MAGs, we need to perform quality control to 
    ensure that the results that get is valid and not from contamination
    """
    input:
        flag        = f"{OUTDIR}/{{org}}/done.flag",
        genomes_dir = f"{OUTDIR}/{{org}}/genomes"
    output:
        outdir         = directory(f"{OUTDIR}/checkm2/{{org}}"),
        checkm2_flag   = f"{OUTDIR}/checkm2/{{org}}/checkm2_done.flag",
        quality_report = f"{OUTDIR}/checkm2/{{org}}/quality_report.tsv"
    threads: 16
    params:
        db = config["checkm2"]["db_path"]
    conda:
        f"{config.get('env_dir')}/checkm2.yaml"
    shell:
        """
        checkm2 predict \
            --input {input.genomes_dir} \
            --output-directory {output.outdir} \
            --database_path {params.db} \
            --extension fna \
            --threads {threads} \
            --force

        touch {output.checkm2_flag}
        """


rule link_filtered:
    # create symlink for files that pass checkm2 parameter thresholds
    input:
        quality_report = f"{OUTDIR}/checkm2/{{org}}/quality_report.tsv",
        genomes_dir    = lambda wc: stage_dir(wc.org, "raw")   # FIX: was prev_stage_dir(wc.org, "filtered")
    output:
        filtered_dir  = directory(f"{OUTDIR}/{{org}}/filtered"),
        filtered_list = f"{OUTDIR}/{{org}}/filtered/passed_genomes.txt"
    threads: 1
    params:
        cont         = config["checkm2"]["Contamination"],
        completeness = config["checkm2"]["Completeness"]
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    shell:
        """
        mkdir -p {output.filtered_dir}

        awk -F' ' \
            -v completeness={params.completeness} \
            -v cont={params.cont} \
            'NR > 1 && $2 >= completeness && $3 <= cont {{ print $1 }}' \
            {input.quality_report} \
        > {output.filtered_list}

        while read genome; do
            ln -s {input.genomes_dir}/${{genome}}.fna {output.filtered_dir}/
        done < {output.filtered_list}
        """


rule skder:
    # Deduplication of genomes to avoid over-representation of any genome
    input:
        genomes_dir = lambda wc: prev_stage_dir(wc.org, "derep"),
        stage_list  = lambda wc: f"{prev_stage_dir(wc.org, 'derep')}/passed_genomes.txt"
    output:
        derep_dir  = directory(f"{OUTDIR}/skder/{{org}}"),
        derep_list = f"{OUTDIR}/skder/{{org}}/derep_genomes.txt",
        flag       = f"{OUTDIR}/skder/{{org}}/dedup_done.flag",
    threads: 16
    params:
        ani    = config['deduplication']['ani'],
        min_af = config['deduplication']['min_af']
    conda:
        f"{config.get('env_dir')}/skder.yaml"
    shell:
        """
        skder -g {input.genomes_dir} \
              -o {output.derep_dir}  \
              -i {params.ani}        \
              -f {params.min_af}     \
              -c {threads}

        ls {output.derep_dir}/Dereplicated_Representative_Genomes/ \
            | sed 's/\\.fna$//' \
            > {output.derep_list}

        touch {output.flag}
        """


