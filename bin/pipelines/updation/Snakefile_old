# helper functions to get the bakta, interproscan and collation output for all genomes
def _get_filtered_genome_list(org):
    csv_path = checkpoints.split_taxonomy.get(org=org).output[0]
    df = pd.read_csv(csv_path)
    phyla = config['interproscan']['phylum_filter']
    if isinstance(phyla, str):
        phyla = [phyla]
    return df[df['phylum'].isin(phyla)]['user_genome'].tolist()


def filtered_genomes_for_org(wildcards):
    genomes = _get_filtered_genome_list(wildcards.org)
    return expand(f"{BAKTA_OUTDIR}/{{org}}/{{genome}}/{{genome}}_domains.tsv",
                  org=wildcards.org, genome=genomes)

def filtered_faa_for_org(wildcards):
    genomes = _get_filtered_genome_list(wildcards.org)
    return expand(f"{BAKTA_OUTDIR}/{{org}}/{{genome}}/{{genome}}.faa",
                  org=wildcards.org, genome=genomes)

def filtered_tsv_for_org(wildcards):
    genomes = _get_filtered_genome_list(wildcards.org)
    return expand(f"{BAKTA_OUTDIR}/{{org}}/{{genome}}/{{genome}}.tsv",
                  org=wildcards.org, genome=genomes)



