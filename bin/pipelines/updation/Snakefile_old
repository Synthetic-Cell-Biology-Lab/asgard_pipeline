rule make_genome_csv:
    input:
        flag   = f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk_done.flag",
        checkm2=lambda wc: expand(
            f"{OUTDIR}/checkm2/{{org}}/quality_report.tsv",
            org=ORGS
        ),
        taxonomy=lambda wc: expand(
            f"{OUTDIR}/gtdbtk/{{org}}_gtdbtk_classification_split.ar53.csv",
            org=ORGS
        )
    output:
        filtered=f"{config["out_genome_csv"]}_{{org}}.csv",
        unfiltered=f"{config["out_genome_csv_unfiltered"]}_{{org}}.csv"
    params:
        completeness=config["checkm2"]["Completeness"],
        contamination=config["checkm2"]["Contamination"]
    run:
        import pandas as pd

        checkm2 = pd.concat(
            [pd.read_csv(f, sep="\t") for f in input.checkm2],
            ignore_index=True
        )

        taxonomy = pd.concat(
            [pd.read_csv(f) for f in input.taxonomy],
            ignore_index=True
        )

        df = checkm2.merge(
            taxonomy[
                [
                    "genome_file",
                    "domain",
                    "phylum",
                    "class",
                    "order",
                    "family",
                    "genus",
                    "species",
                ]
            ],
            left_on="Name",
            right_on="genome_file",
            how="left",
        )

        out = pd.DataFrame({
            "Organism Name": "",
            "Organism Infraspecific Names Strain": "",
            "Organism Infraspecific Names Isolate": "",
            "Annotation Name": "",
            "Assembly Level": "",
            "Assembly Release Date": "",
            "WGS project accession": "",
            "Assembly Stats Number of Scaffolds": "",
            "genome_file": df["genome_file"],
            "Completeness": df["Completeness"],
            "Contamination": df["Contamination"],
            "Completeness_Model_Used": df["Completeness_Model_Used"],
            "Translation_Table_Used": df["Translation_Table_Used"],
            "Coding_Density": df["Coding_Density"],
            "Contig_N50": df["Contig_N50"],
            "Average_Gene_Length": df["Average_Gene_Length"],
            "Genome_Size": df["Genome_Size"],
            "GC_Content": df["GC_Content"],
            "Total_Coding_Sequences": df["Total_Coding_Sequences"],
            "Total_Contigs": df["Total_Contigs"],
            "Max_Contig_Length": df["Max_Contig_Length"],
            "batch_date": "",
            "Isolate": "",
            "WGS Project Accession": "",
            "domain": df["domain"],
            "phylum": df["phylum"],
            "class": df["class"],
            "order": df["order"],
            "family": df["family"],
            "genus": df["genus"],
            "species": df["species"],
        })

        # Write unfiltered table
        out.to_csv(output.unfiltered, index=False)

        # Apply CheckM2 thresholds
        filtered = out[
            (out["Completeness"] >= params.completeness)
            & (out["Contamination"] <= params.contamination)
        ]

        filtered.to_csv(output.filtered, index=False)


rule make_protein_csv:
    input:
        genomes = filtered_tsv_for_org,
        done_flag = f"{OUTDIR}/interproscan/{{org}}/ips_done.flag"
    output:
        f"{config["out_protein_csv"]}_{{org}}.csv"
    run:
        import pandas as pd

        dfs = []

        for file in input.genomes:
            genome = Path(file).stem

            with open(file) as f:
                text = next(f)

            
            if "bakta" in text:
                df = pd.read_csv(file, sep="\t", skiprows=5)
                with open("test", 'a') as f:
                    f.write("1"+"\n")
            else:
                df = pd.read_csv(file, sep = "\t")
                with open("test", 'a') as f:
                    f.write("2"+"\n")

            # -------------------------
            # Bakta
            # -------------------------
            if "Locus Tag" in df.columns:
                df = df.rename(columns={
                    "Locus Tag": "locus_tag",
                    "Type": "ftype",
                    "Gene": "gene",
                    "Product": "product",
                })

                df["length_bp"] = (df["Stop"] - df["Start"] + 1).abs()

                if "Length AA" in df.columns:
                    df["protein_length"] = df["Length AA"]
                elif "Length (aa)" in df.columns:
                    df["protein_length"] = df["Length (aa)"]
                else:
                    df["protein_length"] = ""

                df["EC_number"] = ""
                df["COG"] = ""

            # -------------------------
            # Prokka
            # -------------------------
            elif "locus_tag" in df.columns:
                if "protein_length" not in df.columns:
                    df["protein_length"] = ""

            else:
                raise ValueError(
                    f"Could not determine annotation format for {file}.\n"
                    f"Columns: {list(df.columns)}"
                )

            out = pd.DataFrame({
                "locus_tag": df["locus_tag"],
                "genome_file": genome,
                "protein_length": df["protein_length"],
                "protein_header": "",
                "ftype": df["ftype"],
                "length_bp": df["length_bp"],
                "gene": df["gene"],
                "EC_number": df["EC_number"],
                "COG": df["COG"],
                "product": df["product"],
                "predicted_structure": "",
                "IPS": "",
                "Manual_annotation": "",
            })

            dfs.append(out)

        pd.concat(dfs, ignore_index=True).to_csv(output[0], index=False)