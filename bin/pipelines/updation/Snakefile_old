def stage_dir(org, stage):
    stage_map = {
        "raw":      f"{OUTDIR}/{org}/genomes",
        "filtered": f"{OUTDIR}/{org}/filtered",
        "derep":    f"{OUTDIR}/skder/{org}",
    }
    return stage_map[stage]


def prev_stage_dir(org, stage):
    idx = STAGES.index(stage)
    if idx == 0:
        raise ValueError(f"Stage '{stage}' has no previous stage")
    return stage_dir(org, STAGES[idx - 1])


def get_org_param(wc, field, default=None):
    org = next(
        o for o in config["organisms"]
        if o["name"].replace(" ", "_").lower() == wc.org
    )
    return org.get(field, default)


