checkpoint split_taxonomy:
    # split the taxonomic levels into individual columns from the gtdbtk output
    # also a checkpoint to revise the processes required to be run
    input:
        flag   = f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk_done.flag"

    output:
        f"{OUTDIR}/gtdbtk/{{org}}_gtdbtk_classification_split.ar53.csv"
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    params:
        tsv_file = f"{OUTDIR}/gtdbtk/{{org}}/gtdbtk.ar53.summary.tsv"
    run:
        import pandas as pd

        df = pd.read_csv(params.tsv_file, sep="\t")

        ranks = ["domain", "phylum", "class",
                 "order", "family", "genus", "species"]

        tax_split = (
            df["classification"]
            .str.split(";", expand=True)
            .iloc[:, :7]
        )
        tax_split.columns = ranks

        for col in ranks:
            tax_split[col] = tax_split[col].str.replace(
                r"^[dpcofgs]__", "", regex=True
            )

        df = pd.concat([df, tax_split], axis=1)
        df['genome_file'] = df['user_genome']
        df.to_csv(output[0], index=False)


