########################################
# Main Snakefile
########################################

from datetime import datetime
import os
import shutil
import sys
import glob


shell.executable("/bin/bash")

# Expect config from CLI
# syncing nested config inputs with non nested (to be phased out)

def _cfg_get(path, default=None):
    cur = config
    for key in path:
        if not isinstance(cur, dict) or key not in cur:
            return default
        cur = cur[key]
    return cur


def _cfg_sync(flat_key, nested_path, default=None):
    nested_val = _cfg_get(nested_path, None)
    if nested_val is not None and flat_key not in config:
        config[flat_key] = nested_val
    elif flat_key in config and nested_val is None:
        cur = config
        for key in nested_path[:-1]:
            cur = cur.setdefault(key, {})
        cur[nested_path[-1]] = config[flat_key]
    elif flat_key not in config and nested_val is None and default is not None:
        config[flat_key] = default


_cfg_sync("base_dir", ["run", "base_dir"])
_cfg_sync("env_dir", ["run", "env_dir"])
_cfg_sync("log_dir", ["run", "log_dir"])
_cfg_sync("pipeline_log", ["run", "pipeline_log"])
_cfg_sync("cores", ["run", "cores"])
_cfg_sync("database", ["inputs", "database"])
_cfg_sync("raw_database", ["inputs", "raw_database"])
_cfg_sync("genome_file", ["inputs", "genome_file"])
_cfg_sync("protein_file", ["inputs", "protein_file"])
_cfg_sync("fasta_file", ["inputs", "fasta_file"])
_cfg_sync("from_database", ["modes", "from_database", "enabled"])
_cfg_sync("phylogeny_threads", ["phylogeny", "threads"])
_cfg_sync("run_itol_upload", ["phylogeny", "run_itol_upload"])
_cfg_sync("itol_project", ["phylogeny", "itol_project"])
_cfg_sync("PLOT_Y_COLUMN", ["plot", "y_column"])
_cfg_sync("PLOT_FILTER_COLUMN", ["plot", "filter_column"])
_cfg_sync("PLOT_FILTER_VALS", ["plot", "filter_values"])
_cfg_sync("PLOT_TAXON_LEVELS", ["plot", "taxon_levels"])
_cfg_sync("PLOT_PROTEINS_PRESENCE", ["plot", "proteins_presence"])
_cfg_sync("ymin", ["plot", "ymin"])
_cfg_sync("ymax", ["plot", "ymax"])

# throw error if no config
if not config:
    raise ValueError("No config provided. Use --configfile.")


# Name of the protein to define the output directory
PROTEIN = config["run"]["protein_name"]

LOG = config['pipeline_log']

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
RUN_ID = config.get("run").get("id", TIMESTAMP)

# Define the paths for output
BASE_DIR = os.getcwd()
CURRENT_DIR = config.get(run, {}).get('base_dir', workflow.basedir)
RESULT_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}"
EXPLORATION_DIR = f"{RESULT_DIR}/extraction_exploration"
PHYLO_DIR = f"{RESULT_DIR}/final_phylogeny"
SSN_DIR =  f"{RESULT_DIR}/Sequence_similarity_network"
LOG_DIR = f"{RESULT_DIR}/Logs"
BENCHMARK_DIR = f"{RESULT_DIR}/benchmark_dir"
ENV_DIR = config.get("run", [])['env_dir']

# Create directories
os.makedirs(RESULT_DIR, exist_ok=True)
os.makedirs(EXPLORATION_DIR, exist_ok=True)
os.makedirs(PHYLO_DIR, exist_ok = True)
os.makedirs(LOG_DIR, exist_ok = True)
os.makedirs(BENCHMARK_DIR, exist_ok = True)

# Include rule definitions
"""
This set of rules define the method of extracting proteins from 
the database.
Parse_ips: obtains proteins from string searches of Interproscan desc in collated
Hmmsearch: searches based on ids present in interproscan output
From_manual: retrieves the proteins from previously defined manual annotation in collated protein_file csv
from_fasta_csv: inherits the sequences from a given csv and fasta file.
"""

if config.get("modes", {}).get("parse_ips", False):
    include: "../rules/parse_ips.smk"
elif config.get("modes", {}).get("hmmsearch", False):
    include: "../rules/hmmsearch.smk"
elif config.get("modes", {}).get("from_manual", False):
    include: "../rules/from_manual.smk"
elif config.get("modes", {}).get("from_fasta_csv", False):
    include: "../rules/from_fasta_and_csv.smk"
else:
    print("Must include atleast one mode of id extraction")
    sys.exit()


"""
Adds the rules present in exploration and ssn_3 snakemake files.

"""
include: "../rules/exploration.smk"
include: "../rules/ssn_3.smk"
########################################
# Final Target
########################################
FINAL_TARGETS = [
    f"{RESULT_DIR}/phylogeny_pipeline.log",
    f"{EXPLORATION_DIR}/{PROTEIN}_length_hist.png",
    expand(f"{SSN_DIR}/copied_to_windows.flag") if config.get("SSN", {}).get("copy_to_windows", False) else [],
    f"{SSN_DIR}/{PROTEIN}.clusters.csv",
    f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_abs.unr.svg",
    f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_cond.unr.svg",

]


# add plots
FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.svg",
        level=config.get("plot")("taxon_levels")
    )
)

FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.unr.svg",
        level=config.get("plot")("taxon_levels")
    )
)


FINAL_TARGETS.extend(
    f"{EXPLORATION_DIR}/{PROTEIN}_taxa_count.svg"
)


if config.get("phylogeny", []).get("madroot", False):
    FINAL_TARGETS.append(f"{EXPLORATION_DIR}/{PROTEIN}_unr_fasttree.rooted.treefile")
else:
    FINAL_TARGETS.append(f"{EXPLORATION_DIR}/{PROTEIN}_unr_fasttree.treefile")


if config.get("phylogeny", []).get("run_itol_upload", False):
    FINAL_TARGETS.append(f"{EXPLORATION_DIR}/{PROTEIN}_fast_itol_uploaded.flag")
else:
    pass




FINAL_TARGETS.extend(
        [f"{SSN_DIR}/{PROTEIN}.nr.fasta",
        f"{SSN_DIR}/{PROTEIN}.similarities.tsv",
        f"{SSN_DIR}/{PROTEIN}.clusters.csv"
        ]
    )

rule all:
    input:
        FINAL_TARGETS


rule link_log_file:
    output:
        f"{RESULT_DIR}/phylogeny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"



############################################
# taxa plotting from unr.csv
############################################


rule protein_copy_heatmap_unreviewed:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.unr.svg"

    params:
        proteins = config.get("plot", []).get("proteins_presence", ["FtsZ1","FtsZ2","CetZ","Tubulin"])

    wildcard_constraints:
        level="|".join(config.get("plot", []).get("taxon_levels", ["class"]))
    
    conda: 
        f"{ENV_DIR}/bio-r.yaml"

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/bubble_heat_map_presence_table.r \
        {input.csv} \
        {wildcards.level} \
        genome_file \
        Manual_annotation \
        {output} \
        --proteins {params.proteins:q}
        """


rule protein_coencoding_heatmap_unreviewed:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        abso  = f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_abs.unr.svg",
        cond = f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_cond.unr.svg"

    params:
        proteins = config.get("plot", []).get("proteins_presence", ["FtsZ1","FtsZ2","CetZ","Tubulin"])
        group_col = config.get("plot", []).get("taxon_levels", "class")

    conda:
        f"{ENV_DIR}/bio-r.yaml"

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/coencoding_heatmap.r \
        {input.csv} \
        genome_file \
        Manual_annotation \
        {output.abso} \
        {output.cond} \
        --proteins {params.proteins:q} \
        --group_col {params.group_col}
        """

rule plot_taxa:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv",

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.svg"

    params:
        y = config.get("plot", []).get("y_column","protein_length"),
        filter_col = config.get("plot",[]).get("filter_column", "Manual_annotation"),
        filter_vals = config.get("plot", []).get("filter_values", ['FtsZ1','FtsZ2','CetZ','Tubulin']),
        ymin = config.get("plot", []).get("ymin", 0),
        ymax = config.get("plot", []).get("ymax", 0), 
        dual_vals = config.get("plot", []).get("dual_proteins", ['FtsZ1','FtsZ2']),
        dual_arg = lambda wildcards: (
            "--dual " + " ".join(config.get("plot",[]).get("dual_proteins", []))
            if config.get("plot", []).get("dual_proteins", [])
            else ""
        )
    
    conda: 
        f"{ENV_DIR}/bio-r.yaml"


    wildcard_constraints:
        level="|".join(config.get('plot').get("taxon_levels", ["class"]))

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/taxon_violin_plot.r \
        {input.csv} \
        {params.y} \
        {wildcards.level} \
        {output} \
        --filter {params.filter_col} {params.filter_vals:q} \
        --ymin {params.ymin} --ymax {params.ymax} \
        {params.dual_arg}
        """
