FINAL_TARGETS = [
    f"{RESULT_DIR}/REVIEW_DONE.flag",
    f"{RESULT_DIR}/phylogeny_pipeline.log",
    f"{EXPLORATION_DIR}/{PROTEIN}_length_hist.png",
    expand(f"{SSN_DIR}/copied_to_windows.flag") if config.get("copy_to_windows", False) else [],
    f"{SSN_DIR}/{PROTEIN}.clusters.csv",
    f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_abs.unr.svg",
    f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_cond.unr.svg"
]


# add plots
FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.svg",
        level=config.get("PLOT_TAXON_LEVELS")
    )
)

FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.unr.svg",
        level=config.get("PLOT_TAXON_LEVELS")
    )
)


FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.rev.svg",
        level=config.get("PLOT_TAXON_LEVELS")
    )
)


FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/{PROTEIN}_taxa_count.svg",
    )
)


FINAL_TARGETS.extend(
        [f"{SSN_DIR}/{PROTEIN}.nr.fasta",
        f"{SSN_DIR}/{PROTEIN}.similarities.tsv",
        f"{SSN_DIR}/{PROTEIN}.clusters.csv"
        ]
    )

rule all:
    input:
        FINAL_TARGETS


rule link_log_file:
    output:
        f"{RESULT_DIR}/phylogeny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"



############################################
# taxa plotting from unr.csv
############################################


rule protein_copy_heatmap_unreviewed:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.unr.svg"

    params:
        proteins = config.get("PLOT_PROTEINS_PRESENCE", ["FtsZ1","FtsZ2","CetZ","Tubulin"])

    wildcard_constraints:
        level="|".join(config.get("PLOT_TAXON_LEVELS", ["class"]))
    
    conda: 
        f"{config['env_dir']}/bio-r.yaml"

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/bubble_heat_map_presence_table.r \
        {input.csv} \
        {wildcards.level} \
        genome_file \
        Manual_annotation \
        {output} \
        --proteins {params.proteins:q}
        """


rule protein_coencoding_heatmap_unreviewed:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        abso  = f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_abs.unr.svg",
        cond = f"{EXPLORATION_DIR}/plots/{PROTEIN}/coencoding_cond.unr.svg"

    params:
        proteins = config.get("PLOT_PROTEINS_PRESENCE", ["FtsZ1","FtsZ2","CetZ","Tubulin"]),
        group_col = config.get("PLOT_TAXON_LEVEL", "class")

    conda:
        f"{config['env_dir']}/bio-r.yaml"

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/coencoding_heatmap.r \
        {input.csv} \
        genome_file \
        Manual_annotation \
        {output.abso} \
        {output.cond} \
        --proteins {params.proteins:q} \
        --group_col {params.group_col}
        """

rule plot_taxa:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv",

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.svg"

    params:
        y = config.get("PLOT_Y_COLUMN","protein_length"),
        filter_col = config.get("PLOT_FILTER_COLUMN", "Manual_annotation"),
        filter_vals = config.get("PLOT_FILTER_VALS", ['FtsZ1','FtsZ2','CetZ','Tubulin']),
        ymin = config['ymin'],
        ymax = config['ymax'], 
        dual_vals = config.get("PLOT_DUAL_PROTEINS", ['FtsZ1','FtsZ2']),
        dual_arg = lambda wildcards: (
            "--dual " + " ".join(config.get("PLOT_DUAL_PROTEINS", []))
            if config.get("PLOT_DUAL_PROTEINS", [])
            else ""
        )
    
    conda: 
        f"{config['env_dir']}/bio-r.yaml"


    wildcard_constraints:
        level="|".join(config.get("PLOT_TAXON_LEVELS", ["class"]))

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/taxon_violin_plot.r \
        {input.csv} \
        {params.y} \
        {wildcards.level} \
        {output} \
        --filter {params.filter_col} {params.filter_vals:q} \
        --ymin {params.ymin} --ymax {params.ymax} \
        {params.dual_arg}
        """

rule protein_copy_heatmap_reviewed:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.rev.csv"

    output:
