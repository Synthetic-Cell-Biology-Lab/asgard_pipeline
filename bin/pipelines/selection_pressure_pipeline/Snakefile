rule parse_hyphy:
    input:
        fel=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}.FEL.json",
        meme=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}.MEME.json",
        fubar=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}.FUBAR.json",
        absrel=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}.aBSREL.json",
        slac=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}.SLAC.json"
    output:
        fel_csv=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_FEL.csv",
        meme_csv=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_MEME.csv",
        fubar_csv=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_FUBAR.csv",
        absrel_csv=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_aBSREL.csv",
        slac_csv=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_slac.csv"
    params:
        outdir=f"{SELECTION_DIR}/{{protein}}/tests"
    
    conda:
        f"{config.get('env_dir')}/Reg.yaml"        
    shell:
        """
        python bin/units/hyphy_parser.py \
            --fel {input.fel} \
            --meme {input.meme} \
            --fubar {input.fubar} \
            --absrel {input.absrel} \
            --slac {input.slac} \
            --outdir {params.outdir} \
            --prefix {wildcards.protein}
        """


rule analyze_hyphy:
    input:
        fel=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_FEL.csv",
        meme=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_MEME.csv",
        fubar=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_FUBAR.csv",
        absrel=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_aBSREL.csv",
        slac=f"{SELECTION_DIR}/{{protein}}/tests/{{protein}}_slac.csv"
    output:
        plot=f"{SELECTION_DIR}/{{protein}}/analysis/plots/{{protein}}_selection_plot.png",
        summary=f"{SELECTION_DIR}/{{protein}}/analysis/summary/{{protein}}_summary.csv",
        itol=f"{SELECTION_DIR}/{{protein}}/analysis/itol/{{protein}}_absrel.txt"
    params:
        outdir=f"{SELECTION_DIR}/{{protein}}/analysis"
    conda:
        f"{config.get('env_dir')}/Reg.yaml"
    shell:
        """
        python bin/units/hyphy_analysis.py \
            --fel {input.fel} \
            --meme {input.meme} \
            --fubar {input.fubar} \
            --absrel {input.absrel} \
            --slac {input.slac} \
            --outdir {params.outdir} \
            --prefix {wildcards.protein}
        """



