rule cdhit_100:
    input:
        fasta = f"{PARENT_DIR}/{PROTEIN}.final.fasta"
    output:
        fasta   = f"{PARENT_DIR}/{PROTEIN}.final.nr.fasta"
    conda:
        f"{ENV_DIR}/ssn.yaml"
    threads: 8
    shell:
        """
        cd-hit \
            -i {input.fasta} \
            -o {output.fasta} \
            -c 1.0 \
            -n 5 \
            -M 16000 \
            -T {threads} \
            -d 0
        """


