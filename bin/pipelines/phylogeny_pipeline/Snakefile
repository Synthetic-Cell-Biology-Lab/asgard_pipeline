shell.executable("/bin/bash")

envvars:
    "NCBI_API_KEY",
    "NCBI_EMAIL"

if not config:
    raise ValueError("No config provided. Use --configfile.")

PROTEIN        = config['run']["protein_name"]
LOG            = config["pipeline_log"]

"""
Phylogeny pipeline inherits the exploration data from a previous run of
extraction pipeline. Therefore, the pipeline will make sub folders within
a given extraction pipeline output folder (can be several different runs
per extraction run). 
"""
# the phyl id is the name of the folder which will hold the outputs for the phylogeny pipeline
RUN_ID         = config.get('run').get("phyl_id")
# exploration id is the id of the extraction pipeline run that this phylogeny run will inherit
EXPLORATION_ID = config.get("run").get("id")

if not RUN_ID:
    raise ValueError("run_id is required.")
if not EXPLORATION_ID:
    raise ValueError("exploration_id is required.")

BASE_DIR        = os.getcwd()
CURRENT_DIR = config['run'].get('base_dir', workflow.basedir)
EXPLORATION_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{EXPLORATION_ID}/extraction_exploration"
PARENT_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{EXPLORATION_ID}"
PHYLO_DIR       = f"{PARENT_DIR}/final_phylogeny"   # pre-existing, input only
RESULT_DIR      = f"{PARENT_DIR}/{RUN_ID}"          # all new outputs go here
LOG_DIR         = f"{RESULT_DIR}/Logs"
ENV_DIR = f"{config['run']['env_dir']}"

os.makedirs(RESULT_DIR, exist_ok=True)
os.makedirs(LOG_DIR,    exist_ok=True)

# if config.get("from_manual", False):
#     include: "../extraction_pipeline/rules/from_manual.smk"
# elif config.get("from_fasta_csv", False):
#     include: "../extraction_pipeline/rules/from_fasta_and_csv.smk"

############################################################
# Helpers
############################################################


def get_align_fasta(wildcards):
    if config['phylogeny'].get("extend_phylogeny", {}).get("add_sequences", False):
        return f"{PARENT_DIR}/{PROTEIN}.final.nr.fasta"
    return f"{PARENT_DIR}/{PROTEIN}.final.fasta"

def iqtree_optional_flags(p):
    flags = []
    if p.get("bootstrap") not in (None, "null", "None"):
        flags.append(f"{p['bootstrap_method']} {p['bootstrap']}")
        flags.append("--bnni")
    if p.get("alrt") not in (None, "null", "None"):
        flags.append(f"-alrt {p['alrt']}")
    if p.get("outgroup") not in (None, "null", "None"):
        flags.append(f"-o {p['outgroup']}")
    if p.get("niter") not in (None, "null", "None"):
        flags.append(f"-niter {p['niter']}")
    return " ".join(flags)

############################################################
# Rules
############################################################


rule all:
    input:
        f"{RESULT_DIR}/{PROTEIN}_phylo.treefile",
        f"{RESULT_DIR}/phylogeny_pipeline.log",
        f"{RESULT_DIR}/{PROTEIN}_itol_uploaded.flag"


rule assert_review_inputs:
    output:
        touch(f"{RESULT_DIR}/PHYLOGENY_INPUTS_READY.flag")
    params:
        rev_fasta   = f"{PARENT_DIR}/{PROTEIN}.rev.fasta",
    run:
        missing = [
            p for p in [params.rev_fasta]
            if not os.path.exists(p)
        ]
        if missing:
            raise ValueError(
                "Missing continuation inputs: " + ", ".join(missing)
            )


rule make_rev_csv:
    input:
        rev_fasta = f"{PARENT_DIR}/{PROTEIN}.rev.fasta",
        unr_csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"
    output:
        rev_csv = f"{PARENT_DIR}/{PROTEIN}.rev.csv"
    
    conda:
        f"{ENV_DIR}/Reg.yaml"

    run:
        import pandas as pd

        # ── Extract locus_tags from FASTA ───────────────────────
        locus_tags = set()

        with open(input.rev_fasta) as f:
            for line in f:  
                if line.startswith(">"):
                    locus = line[1:].strip().split()[0]
                    locus_tags.add(locus)

        # ── Load CSV ────────────────────────────────────────────
        df = pd.read_csv(input.unr_csv)

        if "locus_tag" not in df.columns:
            raise ValueError("Column 'locus_tag' not found in CSV")

        # Clean just in case
        df["locus_tag"] = df["locus_tag"].astype(str).str.strip()

        # ── Filter ──────────────────────────────────────────────
        filtered = df[df["locus_tag"].isin(locus_tags)]

        # ── Save ────────────────────────────────────────────────
        filtered.to_csv(output.rev_csv, index=False)

        # ── Debug (optional but useful) ─────────────────────────
        print(f"Extracted {len(locus_tags)} locus tags")
        print(f"Matched {len(filtered)} rows")


