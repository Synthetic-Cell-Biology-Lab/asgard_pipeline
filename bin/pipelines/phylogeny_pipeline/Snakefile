from datetime import datetime
import os

shell.executable("/bin/bash")

if not config:
    raise ValueError("No config provided. Use --configfile.")

PROTEIN = config["protein_name"]
LOG = config["pipeline_log"]
RUN_ID = config.get("run_id")
if not RUN_ID:
    raise ValueError("run_id is required for phylogeny pipeline continuation.")

BASE_DIR = os.getcwd()
RESULT_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}"
PHYLO_DIR = f"{RESULT_DIR}/final_phylogeny"
LOG_DIR = f"{RESULT_DIR}/Logs"
os.makedirs(PHYLO_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)

# Optional helpers: allow curated input creation via existing helper modules
if config.get("from_manual", False):
    include: "rules/from_manual.smk"
elif config.get("from_fasta_csv", False):
    include: "rules/from_fasta_and_csv.smk"

rule all:
    input:
        f"{PHYLO_DIR}/{PROTEIN}_phylo.treefile",
        f"{RESULT_DIR}/phylogeny_pipeline.log"

rule assert_review_inputs:
    output:
        touch(f"{RESULT_DIR}/PHYLOGENY_INPUTS_READY.flag")
    params:
        rev_fasta = f"{RESULT_DIR}/{PROTEIN}.rev.fasta",
        review_flag = f"{RESULT_DIR}/REVIEW_DONE.flag"
    run:
        missing = [p for p in [params.rev_fasta, params.review_flag] if not os.path.exists(p)]
        if missing:
            raise ValueError("Missing continuation inputs: " + ", ".join(missing))

rule run_phylogeny:
    input:
        ready = f"{RESULT_DIR}/PHYLOGENY_INPUTS_READY.flag",
        fasta = f"{RESULT_DIR}/{PROTEIN}.rev.fasta"
    output:
        tree = f"{PHYLO_DIR}/{PROTEIN}_phylo.treefile"
    threads: config.get("phylogeny_threads", 8)
    conda:
        f"{config['env_dir']}/phylogeny.yaml"
    params:
        prefix = f"{PHYLO_DIR}/{PROTEIN}_phylo"
    shell:
        """
        bash bin/units/phylogeny_pipeline.sh \
            {input.fasta} \
            {params.prefix} \
            {threads}
        """

rule link_log_file:
    output:
        f"{RESULT_DIR}/phylogeny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"
