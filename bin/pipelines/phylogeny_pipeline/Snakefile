    output:
        final_csv = f"{PARENT_DIR}/{PROTEIN}.final.csv"
    conda:
        f"{ENV_DIR}/Reg.yaml"
    script:
        "/home/anirudh/asgard_pipeline/bin/units/build_final_metadata_csv.py"

rule align:
    input:
        ready = f"{RESULT_DIR}/PHYLOGENY_INPUTS_READY.flag",
        fasta = get_align_fasta
    output:
        aln   = f"{RESULT_DIR}/{PROTEIN}.aln.fasta"
    threads:
        config['phylogeny']["alignment"].get(
            config['phylogeny']["alignment"]["method"], {}
        ).get("threads", 8)
    params:
        method = config['phylogeny']["alignment"]["method"],
        famsa  = config['phylogeny']["alignment"].get("famsa",  {}),
        mafft  = config['phylogeny']["alignment"].get("mafft",  {}),
        muscle = config['phylogeny']["alignment"].get("muscle", {})
    conda:
        f"{ENV_DIR}/phylogeny.yaml"
    log:
        f"{LOG_DIR}/{PROTEIN}.align.log"
    shell:
        """
        if [ "{params.method}" = "famsa" ]; then
            famsa \
                -t {threads} \
                {params.famsa[extra_args]} \
                {input.fasta} \
                {output.aln} \
            2>&1 | tee {log}

        elif [ "{params.method}" = "mafft" ]; then
            mafft \
                {params.mafft[mode]} \
                --thread {threads} \
                {params.mafft[extra_args]} \
                {input.fasta} \
                > {output.aln} \
                2> >(tee {log} >&2)
        elif [ "{params.method}" = "muscle" ]; then
            muscle \
                {params.muscle[mode]} \
                -threads {threads} \
                {params.muscle[extra_args]} \
                {input.fasta} \
                -output {output.aln} \ 
                2> >(tee {log} >&2)
        else
            echo "Unknown alignment method: {params.method}" >&2
            exit 1
        fi
        """


rule trim:
    input:
        aln     = f"{RESULT_DIR}/{PROTEIN}.aln.fasta"
    output:
        trimmed = f"{RESULT_DIR}/{PROTEIN}.trimmed.fasta"
    params:
        method  = config['phylogeny']["trimming"]["method"],
        trimal  = config['phylogeny']["trimming"].get("trimal",  {}),
        bmge    = config['phylogeny']["trimming"].get("bmge",    {}),
        clipkit = config['phylogeny']["trimming"].get("clipkit", {})
    conda:
        f"{ENV_DIR}/phylogeny.yaml"
    log:
        f"{LOG_DIR}/{PROTEIN}.trim.log"
    shell:
        """
        if [ "{params.method}" = "trimal" ]; then
            trimal \
                -in  {input.aln}          \
                -out {output.trimmed}     \
                {params.trimal[mode]}     \
                {params.trimal[extra_args]} \
            > {log} 2>&1

        elif [ "{params.method}" = "bmge" ]; then
            BMGE \
                -i {input.aln}             \
                -o {output.trimmed}        \
                -t AA                      \
                -m {params.bmge[matrix]}   \
                -g {params.bmge[gap_rate]} \
                -h {params.bmge[entropy]}  \
                {params.bmge[extra_args]}  \
            > {log} 2>&1

        elif [ "{params.method}" = "clipkit" ]; then
            clipkit \
                {input.aln}                  \
                -m {params.clipkit[mode]}    \
                -o {output.trimmed}          \
                {params.clipkit[extra_args]} \
            > {log} 2>&1

        else
            echo "Unknown trimming method: {params.method}" && exit 1
        fi
        """


rule run_phylogeny:
    input:
        ready = f"{RESULT_DIR}/PHYLOGENY_INPUTS_READY.flag",
        fasta = f"{RESULT_DIR}/{PROTEIN}.trimmed.fasta"
    output:
        tree  = f"{RESULT_DIR}/{PROTEIN}_phylo.treefile"
    threads:
        config['phylogeny']["tree"]["iqtree"].get("threads", 16)
    params:
        prefix   = f"{RESULT_DIR}/{PROTEIN}_phylo",
        p        = config['phylogeny']["tree"]["iqtree"],
        optional = iqtree_optional_flags(config['phylogeny']["tree"]["iqtree"])
    conda:
        f"{ENV_DIR}/phylogeny.yaml"
    log:
        f"{LOG_DIR}/{PROTEIN}.iqtree.log"
    shell:
        """
        iqtree \
            -s     {input.fasta}        \
            -m     {params.p[model]}    \
            -st    {params.p[seqtype]}  \
            --prefix {params.prefix}    \
            -seed  {params.p[seed]}     \
            -ninit {params.p[ninit]}    \
            -ntop  {params.p[ntop]}     \
            -nbest {params.p[nbest]}    \
            -nstop {params.p[nstop]}    \
            -nt    {threads}            \
            {params.optional}           \
            --redo                      \
            {params.p[extra_args]}      \
        > {log} 2>&1
        """


rule msa_to_itol:
    input: 
        msa     = f"{RESULT_DIR}/{PROTEIN}.aln.fasta"
    output:
        itol_msa = f"{RESULT_DIR}/itol_msa.txt"
    conda:
        f"{ENV_DIR}/Reg.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/msa_to_itol_dataset.py \
            {input.msa} \
            {output.itol_msa} \
        """

rule table2itol:
    input:
        annot = f"{PARENT_DIR}/{PROTEIN}.final.csv"
    output:
        annotation_dir = directory(f"{RESULT_DIR}/annotation"),    
        done_annot = touch(f"{RESULT_DIR}/annotation.done.flag")
    conda:
        f"{ENV_DIR}/bio-r.yaml"
    params:
        LOCUS_TAG = config['run'].get("LOCUS_TAG", "locus_tag")
    shell:
        """
        mkdir -p {output.annotation_dir}

        Rscript {CURRENT_DIR}/bin/units/table2itol.R \
            -i {params.LOCUS_TAG} \
            -l {params.LOCUS_TAG} \
            -s "," \
            -D {output.annotation_dir} \
            {input.annot}
        """





rule upload_to_itol:
    input:
        tree        = f"{RESULT_DIR}/{PROTEIN}_phylo.treefile",
        colorstrip  = f"{EXPLORATION_DIR}/{PROTEIN}_colorstrip.txt",
        annot_files = lambda wildcards: sorted(
            glob.glob(f"{RESULT_DIR}/annotation/*.txt")
        ),
        default     = lambda wildcards: config['phylogeny'].get("default_annotation") or [] ,
        marker      = f"{RESULT_DIR}/annotation.done.flag",
        itol_dir    = f"{EXPLORATION_DIR}/{PROTEIN}_itol_domains",
        itol_msa    = f"{RESULT_DIR}/itol_msa.txt"
    output:
        tree_ids = f"{RESULT_DIR}/{PROTEIN}_itol_uploaded.flag"
    params:
        project   = config['phylogeny'].get("itol_project", "Asgard"),
        tree_name = f"{RUN_ID}_{PROTEIN}",
        all_annots = lambda wildcards, input: (
            sorted(glob.glob(f"{RESULT_DIR}/annotation/*.txt"))
            + ([input.colorstrip])
            + (input.default if isinstance(input.default, list) else [input.default])
        ),
        domain_files = lambda wildcards, input: sorted(
            glob.glob(f"{input.itol_dir}/*.txt")
        ),
    log:
        f"{LOG_DIR}/{PROTEIN}.itol.log"
    shell:
        """
        bash {CURRENT_DIR}/bin/units/itol_upload.sh \
            {input.tree}            \
            {params.project}        \
            {params.tree_name}      \
            {output.tree_ids}       \
            {params.all_annots:q}   \
            {params.domain_files:q} \
            {input.itol_msa}        \
        > {log} 2>&1
        """


rule link_log_file:
    output:
        f"{RESULT_DIR}/phylogeny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"