_cfg_sync("cores", ["run", "cores"])
_cfg_sync("database", ["inputs", "database"])
_cfg_sync("raw_database", ["inputs", "raw_database"])
_cfg_sync("genome_file", ["inputs", "genome_file"])
_cfg_sync("protein_file", ["inputs", "protein_file"])
_cfg_sync("fasta_file", ["inputs", "fasta_file"])
_cfg_sync("parse_ips", ["modes", "parse_ips", "enabled"])
_cfg_sync("hmmsearch", ["modes", "hmmsearch", "enabled"])
_cfg_sync("from_manual", ["modes", "from_manual", "enabled"])
_cfg_sync("from_database", ["modes", "from_database", "enabled"])
_cfg_sync("from_existing_folder", ["modes", "from_existing_folder", "enabled"])
_cfg_sync("search_string", ["modes", "search", "search_string"])
_cfg_sync("rstring", ["modes", "search", "rstring"])
_cfg_sync("phylogeny_threads", ["phylogeny", "threads"])
_cfg_sync("run_itol_upload", ["phylogeny", "run_itol_upload"])
_cfg_sync("itol_project", ["phylogeny", "itol_project"])
_cfg_sync("PLOT_Y_COLUMN", ["plot", "y_column"])
_cfg_sync("PLOT_FILTER_COLUMN", ["plot", "filter_column"])
