        """
        python bin/pipelines/hmmsearch_pipeline/scripts/extract_hits_fasta.py {input.csv} {input.fasta} {output}
        """



rule review_gate:
    input:
        f"{RESULT_DIR}/hits/final_hits_{RUN_ID}.csv"
    output:
        f"{RESULT_DIR}/reviewed_accessions.tsv"
    message:
        "Please review hits and create reviewed_accessions.tsv"
    run:
        if not os.path.exists(output[0]):
            print("\n=== REVIEW REQUIRED ===")
            print(f"Inspect: {input[0]}")
            print(f"Create file: {output[0]}")
            print("One protein ID per line\n")
            raise ValueError("Manual review step not completed.")


rule extract_genomic_sequences:
