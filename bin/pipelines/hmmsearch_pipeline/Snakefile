
import os
from pathlib import Path
from datetime import datetime

shell.executable("/bin/bash")

if not config:
    raise ValueError("no config provided, use --configfile")

# -------------------------------
# CONFIG
# -------------------------------
BASE_DIR = os.getcwd()
CURRENT_DIR = config.get("run", {}).get('base_dir', workflow.basedir)
RESULT_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}"
PROJECT_NAME = config['run']['protein_name']


TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
RUN_ID = config.get("run").get("id", TIMESTAMP)

RESULT_DIR = OUTDIR / PROJECT_NAME / f"{RUN_ID}"/"hmmsearch"

PFAM_DB = config["inputs"]["pfam"]["hmm_db"]
PFAM_NAMES = config["inputs"]["pfam"]["names"]
DB = config["inputs"]["database"]["fasta"]
ASCOGS = config["inputs"]["database"]["AsCOGs"]
